NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Google OAuth (Continue with Google) ─────────────────────────────────────
#
# A) Google Cloud Console (https://console.cloud.google.com/apis/credentials)
#    1. Create OAuth 2.0 Client ID → Web application
#    2. Authorized JavaScript origins:
#         http://localhost:3000
#         https://YOUR-PRODUCTION-DOMAIN.com
#    3. Authorized redirect URIs (Supabase handles Google callback):
#         https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
#
# B) Supabase Dashboard → Authentication → Providers → Google
#    - Enable Google
#    - Paste Client ID + Client Secret from Google Cloud
#
# C) Supabase Dashboard → Authentication → URL Configuration
#    - Site URL: https://YOUR-PRODUCTION-DOMAIN.com  (or http://localhost:3000 for dev)
#    - Redirect URLs (add ALL of these):
#         http://localhost:3000/auth/callback
#         https://YOUR-PRODUCTION-DOMAIN.com/auth/callback
#
# D) Vercel env vars: same NEXT_PUBLIC_SUPABASE_* + NEXT_PUBLIC_SITE_URL
#
# Email OTP (Phone / Email tab — codes sent to inbox, no Twilio SMS needed):
#   Supabase → Authentication → Providers → Email → Enable Email OTP
#   Optional: configure custom SMTP for production deliverability
#
# Phone login lookup (server resolves phone → email):
#   Add service role key below (Settings → API → service_role — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Telegram admin alerts (offline customer messages) ───────────────────────
# Option A — private (only you): your numeric user id from getUpdates
# Option B — group (you + team): create a group, add the bot, post "hi", getUpdates
#   Group ids look like -1001234567890 (negative number)
# Multiple recipients: comma-separated, e.g. -1001234567890,5293095037
# 1. Message @BotFather → /newbot → copy bot token
# 2. Run supabase/admin-presence.sql in Supabase SQL Editor
# 3. Add vars to Vercel Production and redeploy
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=-1001234567890

# ── Telegram hourly promo broadcast (optional separate channel) ─────────────
# Uses the SAME bot token above. If TELEGRAM_PROMO_CHAT_ID is unset, promos go to
# TELEGRAM_ADMIN_CHAT_ID. For a public player channel, add the bot as admin there
# and set TELEGRAM_PROMO_CHAT_ID to that channel's -100... id.
# TELEGRAM_PROMO_CHAT_ID=-1009876543210

# Vercel Cron auth — random string; set same value in Vercel → Settings → Environment Variables
CRON_SECRET=generate_a_long_random_secret

# n8n AI blog automation — POST /api/automation/blog with Authorization: Bearer <this secret>
# Generate a long random string; use the SAME value in n8n HTTP Request credentials.
N8N_BLOG_SECRET=generate_a_long_random_secret_for_n8n

# Email (Resend SMTP → Supabase) — spinoracasinos.com
# 1. Resend → Domains → spinoracasinos.com verified (DNS in Cloudflare)
# 2. Resend → API Keys → create key (re_xxxxxxxx) — use ONLY in Supabase SMTP, never in frontend
# 3. Supabase → Project Settings → Authentication → SMTP Settings:
#      Enable Custom SMTP: ON
#      Host: smtp.resend.com
#      Port: 465
#      Username: resend
#      Password: <your Resend API key>
#      Sender email: noreply@spinoracasinos.com
#      Sender name: Spinora
# 4. Supabase → Authentication → Providers → Email:
#      Confirm email: ON  (required — no login until user clicks email link)
# 5. Supabase → Authentication → URL Configuration:
#      Site URL: https://spinoracasinos.com
#      Redirect URLs: https://spinoracasinos.com/auth/callback
#                     http://localhost:3000/auth/callback

