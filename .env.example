# Required — copy values from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URLs (set to your Vercel production URL)
NEXT_PUBLIC_SITE_URL=https://final-file-omega.vercel.app
NEXT_PUBLIC_APP_URL=https://final-file-omega.vercel.app

# Cron jobs (/api/cron/*)
CRON_SECRET=

# AI blog (at least one)
GEMINI_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# Optional — payments, telegram, email
# NOWPAYMENTS_API_KEY=
# NOWPAYMENTS_IPN_SECRET=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=
# RESEND_API_KEY=
