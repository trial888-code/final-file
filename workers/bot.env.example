# Per-bot .env — run sync-bot-env.bat to copy Supabase + CAPTCHA from workers/.env
# Then run set-bot-credentials.bat for agent panel login.

SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

CAPTCHA_SOLVER=2captcha
CAPTCHA_API_KEY=your_2captcha_api_key
CAPTCHA_AUTO=true
CAPTCHA_MAX_RETRIES=5
BOT_POLL_MS=2500

# Unified Chrome (recommended): set at runtime by start scripts — do not commit real values
# JUWA_CDP_URL=http://127.0.0.1:9222
# JUWA_HEADLESS=false

# Agent panel login (required for auto-login)
# JUWA_AGENT_USERNAME=your_agent_user
# JUWA_AGENT_PASSWORD=your_agent_password
# PANEL_USERNAME=your_agent_user
# PANEL_PASSWORD=your_agent_password

# Optional
# JUWA_POLL_MS=10000
# JUWA_ADMIN_URL=https://ht.juwa777.com/login
