# Supabase (same project as Spinora)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Vegas Sweeps agent panel (agent.lasvegassweeps.com)
VEGAS_ADMIN_URL=https://agent.lasvegassweeps.com/login
VEGAS_AGENT_USERNAME=your_agent_username
VEGAS_AGENT_PASSWORD=your_agent_password

# Set false to watch the browser while debugging selectors
VEGAS_HEADLESS=true
VEGAS_POLL_MS=10000

# Use a Chrome you control over CDP (recommended if the panel needs a captcha/VPN):
#   1) run start-chrome-for-bot.bat
#   2) log in to the panel manually in that Chrome
#   3) set VEGAS_CDP_URL and start the bot
# VEGAS_CDP_URL=http://localhost:9223
# VEGAS_CHROME_PROFILE_DIR=C:\spinora\vegas-bot-profile
# VEGAS_BROWSER=chrome
# VEGAS_PROXY=http://user:pass@host:port

# Auto CAPTCHA login (optional — same vars in each bot .env)
# CAPTCHA_API_KEY=your_2captcha_or_capsolver_key
# CAPTCHA_SOLVER=2captcha
# CAPTCHA_MAX_RETRIES=3

# Optional CSS selector overrides — only needed if the defaults miss.
# Fill these after running `npm run codegen` against the live panel.
# VEGAS_SEL_LOGIN_USER=input[placeholder="Account"]
# VEGAS_SEL_LOGIN_PASS=input[type="password"]
# VEGAS_SEL_LOGIN_SUBMIT=button:has-text("Login")
# VEGAS_SEL_NEW_ACCOUNT=button:has-text("New Account")
# VEGAS_SEL_CREATE_USER=input[placeholder="Account"]
# VEGAS_SEL_CREATE_PASS=input[type="password"]
# VEGAS_SEL_CREATE_SUBMIT=button:has-text("Save")
# VEGAS_SEL_SEARCH_INPUT=input[placeholder*="search content" i]
# VEGAS_SEL_SEARCH_SUBMIT=button:has-text("Search")
# VEGAS_SEL_RECHARGE_BTN=button:has-text("Recharge")
# VEGAS_SEL_REDEEM_BTN=button:has-text("Redeem")
# VEGAS_SEL_AMOUNT_INPUT=input[placeholder*="amount" i]
# VEGAS_SEL_CONFIRM_BTN=button:has-text("Confirm")
