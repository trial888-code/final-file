# Supabase (same project as Spinora)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Game Vault agent panel (agent.gamevault999.com)
GAMEVAULT_ADMIN_URL=https://agent.gamevault999.com/login
GAMEVAULT_AGENT_USERNAME=your_agent_username
GAMEVAULT_AGENT_PASSWORD=your_agent_password

# Set false to watch the browser while debugging selectors
GAMEVAULT_HEADLESS=true
GAMEVAULT_POLL_MS=10000

# Use a Chrome you control over CDP (recommended — the panel needs a captcha):
#   1) run start-chrome-for-bot.bat (opens Chrome on port 9224)
#   2) log in to the panel manually in that Chrome
#   3) set GAMEVAULT_CDP_URL and start the bot
# GAMEVAULT_CDP_URL=http://127.0.0.1:9224
# GAMEVAULT_CHROME_PROFILE_DIR=C:\spinora\gamevault-bot-profile
GAMEVAULT_BROWSER=chrome
# GAMEVAULT_PROXY=http://user:pass@host:port

# Auto CAPTCHA login (optional — same vars in each bot .env)
# CAPTCHA_API_KEY=your_2captcha_or_capsolver_key
# CAPTCHA_SOLVER=2captcha
# CAPTCHA_MAX_RETRIES=3

# Optional CSS selector overrides — only needed if the defaults miss.
# VEGAS-style "Backend" panel; defaults usually work as-is.
