# Supabase (same project as Spinora)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Juwa agent panel
JUWA_ADMIN_URL=https://ht.juwa777.com/login
JUWA_AGENT_USERNAME=your_agent_username
JUWA_AGENT_PASSWORD=your_agent_password

# Set false to watch browser while debugging
JUWA_HEADLESS=true
JUWA_POLL_MS=10000

# Auto CAPTCHA login (optional — same vars in each bot .env)
# CAPTCHA_API_KEY=your_2captcha_or_capsolver_key
# CAPTCHA_SOLVER=2captcha
# CAPTCHA_MAX_RETRIES=3

# CSS selectors — fill after npm run codegen (see README)
