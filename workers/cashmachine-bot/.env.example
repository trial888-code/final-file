# Supabase (same project as Spinora)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cash Machine agent panel (agentserver.cashmachine777.com)
CASHMACHINE_ADMIN_URL=https://agentserver.cashmachine777.com/admin/login
CASHMACHINE_AGENT_USERNAME=your_agent_username
CASHMACHINE_AGENT_PASSWORD=your_agent_password

CASHMACHINE_HEADLESS=true
CASHMACHINE_POLL_MS=10000

# CDP mode (recommended — log in manually in bot Chrome):
#   1) run start-chrome-for-bot.bat (port 9226)
#   2) log in at /admin, open User Management
#   3) set CASHMACHINE_CDP_URL and start the bot
# CASHMACHINE_CDP_URL=http://127.0.0.1:9226
# CASHMACHINE_CHROME_PROFILE_DIR=C:\spinora\cashmachine-bot-profile
CASHMACHINE_BROWSER=chrome

# Auto CAPTCHA login (optional — same vars in each bot .env)
# CAPTCHA_API_KEY=your_2captcha_or_capsolver_key
# CAPTCHA_SOLVER=2captcha
# CAPTCHA_MAX_RETRIES=3
