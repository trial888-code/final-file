# Supabase (same project as Spinora)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Gameroom agent panel (agentserver1.gameroom777.com)
GAMEROOM_ADMIN_URL=https://agentserver1.gameroom777.com/admin/login
GAMEROOM_AGENT_USERNAME=your_agent_username
GAMEROOM_AGENT_PASSWORD=your_agent_password

# Set false to watch the browser while debugging selectors
GAMEROOM_HEADLESS=true
GAMEROOM_POLL_MS=10000

# Use a Chrome you control over CDP (recommended — the panel needs a captcha):
#   1) run start-chrome-for-bot.bat (opens Chrome on port 9225)
#   2) log in to the panel manually in that Chrome
#   3) set GAMEROOM_CDP_URL and start the bot
# GAMEROOM_CDP_URL=http://127.0.0.1:9225
# GAMEROOM_CHROME_PROFILE_DIR=C:\spinora\gameroom-bot-profile
GAMEROOM_BROWSER=chrome
# GAMEROOM_PROXY=http://user:pass@host:port

# Bot reads CAPTCHA locally (Tesseract OCR) when session expires — no API key needed.
# CAPTCHA_AUTO=true
# CAPTCHA_MAX_RETRIES=3
# CAPTCHA_OCR_MIN_CONFIDENCE=35
# Auto-login on bot startup + every 5 min (not only when jobs run):
# SESSION_KEEPER=true
# SESSION_CHECK_MS=300000
# Optional paid fallback if local OCR keeps failing:
# CAPTCHA_API_KEY=your_2captcha_or_capsolver_key
# CAPTCHA_SOLVER=2captcha

# Optional route/selector overrides — only needed if the defaults miss.
# GAMEROOM_USER_MGMT_PATH=/userManagement
