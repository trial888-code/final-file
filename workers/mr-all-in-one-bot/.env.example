# Supabase (same project as Spinora)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# MR All In One agent panel (agentserver.mrallinone777.com)
MRALLINONE_ADMIN_URL=https://agentserver.mrallinone777.com/admin/login
MRALLINONE_AGENT_USERNAME=your_agent_username
MRALLINONE_AGENT_PASSWORD=your_agent_password

MRALLINONE_HEADLESS=true
MRALLINONE_POLL_MS=10000

# CDP mode (recommended — log in manually in bot Chrome):
#   1) run start-chrome-for-bot.bat (port 9227)
#   2) log in at /admin, open User Management
#   3) set MRALLINONE_CDP_URL and start the bot
# MRALLINONE_CDP_URL=http://127.0.0.1:9227
# MRALLINONE_CHROME_PROFILE_DIR=C:\spinora\mr-all-in-one-bot-profile
MRALLINONE_BROWSER=chrome

# Auto CAPTCHA login (optional — same vars in each bot .env)
# CAPTCHA_API_KEY=your_2captcha_or_capsolver_key
# CAPTCHA_SOLVER=2captcha
# CAPTCHA_MAX_RETRIES=3
