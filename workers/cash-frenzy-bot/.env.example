# Supabase (same project as Spinora)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cash Frenzy agent panel (agentserver.cashfrenzy777.com)
CASHFRENZY_ADMIN_URL=https://agentserver.cashfrenzy777.com/admin/login
CASHFRENZY_AGENT_USERNAME=your_agent_username
CASHFRENZY_AGENT_PASSWORD=your_agent_password

# Set false to watch the browser while debugging selectors
CASHFRENZY_HEADLESS=true
CASHFRENZY_POLL_MS=10000

# Use a Chrome you control over CDP (recommended — the panel needs a captcha):
#   1) run start-chrome-for-bot.bat (opens Chrome on port 9229)
#   2) log in to the panel manually in that Chrome
#   3) set CASHFRENZY_CDP_URL and start the bot
# CASHFRENZY_CDP_URL=http://127.0.0.1:9229
# CASHFRENZY_CHROME_PROFILE_DIR=C:\spinora\cash-frenzy-bot-profile
CASHFRENZY_BROWSER=chrome
# CASHFRENZY_PROXY=http://user:pass@host:port

# Optional CSS selector overrides — only needed if the defaults miss.
# VEGAS-style "Backend" panel; defaults usually work as-is.
