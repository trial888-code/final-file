# Supabase (same project as Spinora)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Mafia agent panel (agentserver.mafia77777.com)
MAFIA_ADMIN_URL=https://agentserver.mafia77777.com/admin/login
MAFIA_AGENT_USERNAME=your_agent_username
MAFIA_AGENT_PASSWORD=your_agent_password

MAFIA_HEADLESS=true
MAFIA_POLL_MS=10000

# CDP mode (recommended — log in manually in bot Chrome):
#   1) run start-chrome-for-bot.bat (port 9228)
#   2) log in at /admin, open User Management
#   3) set MAFIA_CDP_URL and start the bot
# MAFIA_CDP_URL=http://127.0.0.1:9228
# MAFIA_CHROME_PROFILE_DIR=C:\spinora\mafia-bot-profile
MAFIA_BROWSER=chrome
